---
interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
	title = "The Entropic Limit",
	description = "Entropic Limit Institute. Researching the thermodynamic and computational constraints of the vacuum state.",
	// We force the absolute URL here to ensure iMessage finds it every time.
	image = "https://entropic-limit.org/social-preview.png"
} = Astro.props;

const siteUrl = "https://entropic-limit.org";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
		
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />

		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={siteUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={image} />
	</head>
	<body>
		<div class="scanlines"></div>
		<slot />
	</body>
</html>

<style is:global>
	/* RESET & BASICS */
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html,
	body {
		width: 100%;
		min-height: 100%;
		background: #050505; /* Deepest Black */
		color: #C0C0C0;      /* Standard Terminal Grey */
		font-family: 'IBM Plex Mono', 'Menlo', 'DejaVu Sans Mono', 'Bitstream Vera Sans Mono', Courier, monospace;
		font-size: 14px;
		line-height: 1.6;
		overflow-x: hidden;
		-webkit-font-smoothing: antialiased;
	}

	/* FORCE FONT INHERITANCE ON FORM ELEMENTS */
	button, input, textarea, select {
		font-family: inherit;
	}

	/* SELECTION HIGHLIGHT (Safety Orange) */
	::selection {
		background: #FF4500;
		color: #000000;
	}

	/* SCANLINE EFFECT */
	.scanlines {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		pointer-events: none; /* Allows clicking through */
		z-index: 9999;
		background: repeating-linear-gradient(
			0deg,
			rgba(0, 0, 0, 0.1),
			rgba(0, 0, 0, 0.1) 1px,
			transparent 1px,
			transparent 2px
		);
		backdrop-filter: blur(0.5px); /* Subtle CRT fuzziness */
		opacity: 0.4;
	}

	/* LINKS (Global Default) */
	a {
		color: inherit;
		text-decoration: none;
	}

	/* UTILITY: SCREEN READER ONLY */
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}
</style>
